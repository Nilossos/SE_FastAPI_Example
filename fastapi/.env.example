# Скопировать в .env и при необходимости измените.
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# Используются скриптом run.py (запуск сервера)
API_HOST=127.0.0.1
API_PORT=8000
# Автоперезапуск при изменении кода (для продакена false)
API_RELOAD=true

# Необязательно: модель Hugging Face для sentiment-analysis (пусто = дефолт pipeline)
# SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
